# Streamlit secrets template.
#
# - Locally: copy this file to `.streamlit/secrets.toml` and fill in real values
#   (this file is gitignored). Or, equivalently, put the same keys in `.env`
#   in the project root — both work.
# - On Streamlit Community Cloud: paste the contents below (with real values)
#   into the app's "Secrets" UI under Advanced settings. No file needed.

ANTHROPIC_API_KEY = "sk-ant-..."

# Optional. Override the default Claude model.
# Default = "claude-haiku-4-5-20251001" (fast & cheap).
# Upgrade to "claude-sonnet-4-6" or "claude-opus-4-6" for stronger reasoning.
HOLDEMMATE_MODEL = "claude-haiku-4-5-20251001"

# Number of Monte Carlo trials per equity calculation. Higher = more accurate, slower.
HOLDEMMATE_MC_TRIALS = "2000"

# If set, the whole app is gated behind this shared password. Leave unset
# for fully open access (local dev / demos).
APP_PASSWORD = "change-me-before-deploy"
