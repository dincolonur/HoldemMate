# Copy to .env and fill in your real values.
# This file is read by python-dotenv at startup and is the local equivalent
# of the Streamlit Cloud "Secrets" panel.

ANTHROPIC_API_KEY=sk-ant-...

# Optional. Override the default Claude model used by all agents.
# Default = claude-haiku-4-5-20251001 (fast & cheap).
# Upgrade to claude-sonnet-4-6 or claude-opus-4-6 for stronger reasoning.
HOLDEMMATE_MODEL=claude-haiku-4-5-20251001

# Number of Monte Carlo trials per equity calculation (higher = more accurate, slower).
HOLDEMMATE_MC_TRIALS=2000

# Optional. If set, the whole app is gated behind this shared password.
# Leave unset (or empty) for fully open access during local development.
# APP_PASSWORD=change-me-before-deploy
