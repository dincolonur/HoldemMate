# Copy to .env and fill in your real key.
ANTHROPIC_API_KEY=sk-ant-...

# Optional. Override the default Claude model used by all agents.
# Examples: claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5-20251001
HOLDEMMATE_MODEL=claude-sonnet-4-6

# Number of Monte Carlo trials per equity calculation (higher = more accurate, slower).
HOLDEMMATE_MC_TRIALS=2000
